# Copy to .env to override defaults used by docker-compose.
# Host port the web UI is published on.
DOC_VIEWER_PORT=8090

# Uid/gid the server runs as inside the container. Set to the output of
# `id -u` and `id -g` so files in ./archive belong to your user.
DOC_VIEWER_UID=1000
DOC_VIEWER_GID=1000

# Password for the "admin" user (the only account that can edit files).
# The server seeds it at startup and rotates the stored hash when this value
# changes. If left empty, a random password is generated on first run and
# written once to /app/data/password.txt (inside the data volume).
DOC_VIEWER_ADMIN_PASSWORD=
